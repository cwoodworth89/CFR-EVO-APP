# Supabase API Credentials
SUPABASE_URL=https://your-project-ref.supabase.co
# IMPORTANT: Use the Service Role (secret) key for the backend agent to bypass RLS, not the anon key!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ntfy.sh Push Notification Settings (For Tasker Integration)
NTFY_TOPIC=your-private-ntfy-topic-here
NTFY_TOKEN=your-optional-ntfy-token-here

# Optional: Google Maps Geocoding API Key (If ENABLE_GOOGLE_MAPS_FALLBACK=True in config.py)
GOOGLE_API_KEY=your-google-maps-api-key-here

# Optional: Google Cloud Speech-to-Text V2 Application Credentials (If STT_ENGINE="google" in config.py)
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/gcp-service-account-key.json

# Optional: Join Push Notification Key (If ENABLE_JOIN_PUSH=True in config.py)
JOIN_API_KEY=your-join-api-key-here
